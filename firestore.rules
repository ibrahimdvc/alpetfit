rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net (Default Deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Daily Goals access rules
    match /users/{userId}/goals/current {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId)
        && request.resource.data.calories is number
        && request.resource.data.protein is number
        && request.resource.data.carbs is number
        && request.resource.data.fat is number
        && request.resource.data.water is number;
    }

    // Meals collection access rules
    match /users/{userId}/meals/{mealId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId)
        && isValidId(mealId)
        && (request.resource == null || (
          request.resource.data.id is string
          && request.resource.data.name is string
          && request.resource.data.name.size() <= 500
          && request.resource.data.calories is number
          && request.resource.data.protein is number
          && request.resource.data.carbs is number
          && request.resource.data.fat is number
        ));
    }

    // Water Logs collection access rules
    match /users/{userId}/waterLogs/{waterLogId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId)
        && isValidId(waterLogId)
        && (request.resource == null || (
          request.resource.data.id is string
          && request.resource.data.amountMl is number
        ));
    }

    // Workouts collection access rules
    match /users/{userId}/workouts/{workoutId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId)
        && isValidId(workoutId);
    }
  }
}
